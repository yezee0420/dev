#!/usr/bin/env bash
set -euo pipefail

# ─── Colors & Helpers ───────────────────────────────────────────────
RED='\033[0;31m'  GREEN='\033[0;32m'  YELLOW='\033[1;33m'
CYAN='\033[0;36m' BOLD='\033[1m'      DIM='\033[2m'
NC='\033[0m'

info()    { echo -e "  ${CYAN}▸${NC} $*"; }
success() { echo -e "  ${GREEN}✔${NC} $*"; }
warn()    { echo -e "  ${YELLOW}⚠${NC} $*"; }
die()     { echo -e "  ${RED}✖${NC} $*" >&2; exit 1; }
divider() { echo -e "${DIM}──────────────────────────────────────────────${NC}"; }

# ─── Help ───────────────────────────────────────────────────────────
show_help() {
  cat <<EOF
${BOLD}git-check${NC} — Fetch remote, show what's new, and pull

${BOLD}Usage:${NC}
  git-check              Fetch + show changes + auto pull (default)
  git-check <branch>     Check against a specific remote branch
  git-check --peek       Only check, don't pull

${BOLD}Options:${NC}
  --peek          Fetch & show only (skip pull)
  -h, --help      Show this help
EOF
}

# ─── Parse Arguments ────────────────────────────────────────────────
PEEK_ONLY=false
TARGET_BRANCH=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --peek)     PEEK_ONLY=true; shift ;;
    -h|--help)  show_help; exit 0 ;;
    -*)         die "Unknown option: $1  (use -h for help)" ;;
    *)          TARGET_BRANCH="$1"; shift ;;
  esac
done

# ─── Preflight ──────────────────────────────────────────────────────
git rev-parse --is-inside-work-tree &>/dev/null \
  || die "Not inside a git repository"

CURRENT_BRANCH=$(git branch --show-current)
DEFAULT_BRANCH=$(git remote show origin 2>/dev/null \
  | awk '/HEAD branch/{print $NF}' || echo "main")

COMPARE_BRANCH="${TARGET_BRANCH:-$DEFAULT_BRANCH}"

echo ""
echo -e "${BOLD}🔍 git-check${NC}  ${DIM}local${NC} ${CYAN}${CURRENT_BRANCH}${NC}  ${DIM}vs${NC}  ${GREEN}origin/${COMPARE_BRANCH}${NC}"
divider

# ─── Fetch ──────────────────────────────────────────────────────────
info "Fetching from origin..."
git fetch origin "$COMPARE_BRANCH" --quiet 2>/dev/null \
  || die "Failed to fetch origin/${COMPARE_BRANCH}"
success "Fetch complete"

# ─── Compare ────────────────────────────────────────────────────────
BEHIND=$(git rev-list --count HEAD..origin/"$COMPARE_BRANCH" 2>/dev/null || echo 0)
AHEAD=$(git rev-list --count origin/"$COMPARE_BRANCH"..HEAD 2>/dev/null || echo 0)

echo ""

if [[ "$BEHIND" -eq 0 && "$AHEAD" -eq 0 ]]; then
  success "Up to date — no new changes on origin/${COMPARE_BRANCH}"
else
  if [[ "$BEHIND" -gt 0 ]]; then
    warn "Remote has ${BOLD}${BEHIND}${NC}${YELLOW} new commit(s):${NC}"
    echo ""
    git log --oneline --graph HEAD..origin/"$COMPARE_BRANCH" | sed 's/^/    /'
    echo ""
  fi

  if [[ "$AHEAD" -gt 0 ]]; then
    info "Local has ${BOLD}${AHEAD}${NC} commit(s) not on remote"
  fi

  if [[ "$BEHIND" -gt 0 ]]; then
    if [[ "$PEEK_ONLY" == true ]]; then
      echo -e "  ${DIM}Run${NC} ${BOLD}git-check${NC} ${DIM}(without --peek) to pull${NC}"
    else
      echo ""
      info "Pulling changes..."
      git pull origin "$COMPARE_BRANCH" --rebase --autostash
      success "Pull complete — now up to date"
    fi
  fi
fi

echo ""
divider
echo ""
