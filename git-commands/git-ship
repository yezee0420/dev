#!/usr/bin/env bash
set -euo pipefail

# ─── Colors & Helpers ───────────────────────────────────────────────
RED='\033[0;31m'  GREEN='\033[0;32m'  YELLOW='\033[1;33m'
BLUE='\033[0;34m' CYAN='\033[0;36m'   BOLD='\033[1m'
DIM='\033[2m'     NC='\033[0m'

info()    { echo -e "  ${BLUE}▸${NC} $*" >&2; }
success() { echo -e "  ${GREEN}✔${NC} $*" >&2; }
warn()    { echo -e "  ${YELLOW}⚠${NC} $*" >&2; }
die()     { echo -e "  ${RED}✖${NC} $*" >&2; exit 1; }
step()    { echo -e "\n${CYAN}${BOLD}[$1]${NC} ${BOLD}$2${NC}" >&2; }
divider() { echo -e "${DIM}──────────────────────────────────────────────${NC}" >&2; }

# ─── Help ───────────────────────────────────────────────────────────
show_help() {
  cat <<EOF
${BOLD}git-ship${NC} — Stage → Commit → Pull → Push → PR → Merge in one command

${BOLD}Usage:${NC}
  git-ship                   Auto-generate commit message (interactive)
  git-ship -y                Auto-generate commit message (no prompt)
  git-ship -m "message"      Use custom commit message (skip prompt)
  git-ship --no-pr           Stop after push (skip PR & merge)
  git-ship --no-merge        Create PR but skip merge
  git-ship --dry-run         Preview actions without executing

${BOLD}Options:${NC}
  -y, --yes             Auto-commit without asking (use generated message)
  -m, --message <msg>   Custom commit message
  --no-pr               Skip PR creation and merge
  --no-merge            Create PR but don't merge
  --dry-run             Show what would happen
  -h, --help            Show this help
EOF
}

# ─── Parse Arguments ────────────────────────────────────────────────
CUSTOM_MSG=""
AUTO_YES=false
SKIP_PR=false
SKIP_MERGE=false
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case $1 in
    -y|--yes)    AUTO_YES=true; shift ;;
    -m|--message)
      [[ -z "${2:-}" ]] && die "Option $1 requires a message argument"
      CUSTOM_MSG="$2"; shift 2 ;;
    --no-pr)     SKIP_PR=true; SKIP_MERGE=true; shift ;;
    --no-merge)  SKIP_MERGE=true; shift ;;
    --dry-run)   DRY_RUN=true; shift ;;
    -h|--help)   show_help; exit 0 ;;
    *) die "Unknown option: $1  (use -h for help)" ;;
  esac
done

dry() {
  if [[ "$DRY_RUN" == true ]]; then
    info "${DIM}(dry-run)${NC} $*"
    return 0
  fi
  "$@"
}

# ─── Preflight Checks ──────────────────────────────────────────────
git rev-parse --is-inside-work-tree &>/dev/null \
  || die "Not inside a git repository"

command -v gh &>/dev/null \
  || die "GitHub CLI (gh) required — brew install gh"

if [[ "$SKIP_PR" == false ]]; then
  gh auth status &>/dev/null \
    || die "GitHub CLI not authenticated — run: gh auth login"
fi

# 브랜치 감지 (detached HEAD 시 현재 커밋에서 새 브랜치 생성)
get_current_branch() {
  local branch
  branch=$(git branch --show-current 2>/dev/null)
  if [[ -z "$branch" ]]; then
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
  fi
  if [[ -z "$branch" || "$branch" == "HEAD" ]]; then
    local new_branch
    new_branch="ship/$(date +%Y%m%d-%H%M%S)"
    warn "Detached HEAD — creating branch ${new_branch} from current commit"
    git checkout -b "$new_branch" 2>/dev/null || die "Cannot create branch. Try: git checkout -b temp-branch"
    branch="$new_branch"
  fi
  echo "$branch"
}

# default branch 감지 (빈 값 방어)
get_default_branch() {
  local branch
  branch=$(git remote show origin 2>/dev/null | awk '/HEAD branch/{print $NF}')
  if [[ -z "$branch" ]]; then
    if git show-ref --verify --quiet refs/remotes/origin/main 2>/dev/null; then
      branch="main"
    elif git show-ref --verify --quiet refs/remotes/origin/master 2>/dev/null; then
      branch="master"
    else
      branch="main"
    fi
  fi
  echo "$branch"
}

CURRENT_BRANCH=$(get_current_branch)
ORIGINAL_BRANCH="$CURRENT_BRANCH"
CREATED_BRANCH=""
DEFAULT_BRANCH=$(get_default_branch)

abort_cleanup() {
  if [[ -n "$CREATED_BRANCH" ]]; then
    git checkout "$ORIGINAL_BRANCH" 2>/dev/null || true
    git branch -D "$CREATED_BRANCH" 2>/dev/null || true
    info "Returned to ${ORIGINAL_BRANCH}, deleted ${CREATED_BRANCH}"
  elif [[ "$CURRENT_BRANCH" == ship/* && "$CURRENT_BRANCH" != "$DEFAULT_BRANCH" ]]; then
    git checkout "$DEFAULT_BRANCH" 2>/dev/null || true
    git branch -D "$CURRENT_BRANCH" 2>/dev/null || true
    info "Returned to ${DEFAULT_BRANCH}, deleted leftover ${CURRENT_BRANCH}"
  fi
}

echo "" >&2
echo -e "${BOLD}🚀 git-ship${NC}  ${DIM}on${NC} ${CYAN}${CURRENT_BRANCH}${NC}  ${DIM}→${NC}  ${GREEN}${DEFAULT_BRANCH}${NC}" >&2
divider

# ─── 1. Stage (먼저 확인) ────────────────────────────────────────────
step "1" "Stage Changes"

dry git add -A

STAGED=$(git diff --cached --stat 2>/dev/null || true)
AHEAD=$(git rev-list --count origin/"$DEFAULT_BRANCH"..HEAD 2>/dev/null || echo 0)

UNPUSHED_ONLY=false
if [[ -z "$STAGED" ]]; then
  if [[ "$AHEAD" -gt 0 ]]; then
    info "No new changes — ${AHEAD} unpushed commit(s) will be pushed"
    COMMIT_MSG=$(git log -1 --pretty=%s 2>/dev/null || echo "update")
    UNPUSHED_ONLY=true
  else
    warn "No changes to commit — nothing to ship!"
    abort_cleanup
    exit 0
  fi
else
  echo -e "${DIM}${STAGED}${NC}" >&2
  success "All changes staged"
fi

# ─── 2. Branch (변경 있을 때만 ship/ 생성) ─────────────────────────────
step "2" "Branch"

if [[ -n "$STAGED" && "$CURRENT_BRANCH" == "$DEFAULT_BRANCH" ]]; then
  NEW_BRANCH="ship/$(date +%Y%m%d-%H%M%S)"
  warn "On ${DEFAULT_BRANCH} — creating feature branch: ${NEW_BRANCH}"
  dry git checkout -b "$NEW_BRANCH"
  CREATED_BRANCH="$NEW_BRANCH"
  CURRENT_BRANCH="$NEW_BRANCH"
  success "Switched to ${CURRENT_BRANCH}"
else
  success "Branch: ${CURRENT_BRANCH}"
fi

# ─── 3. Commit ──────────────────────────────────────────────────────
if [[ -n "$STAGED" ]]; then
step "3" "Commit"

ai_summarize() {
  [[ -z "${ANTHROPIC_API_KEY:-}" ]] && return 1

  local tmp
  tmp=$(mktemp)
  git diff --cached --no-color | head -4000 > "$tmp"
  [[ -s "$tmp" ]] || { rm -f "$tmp"; return 1; }

  local msg
  msg=$(ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY}" python3 - "$tmp" << 'PYEOF'
import json, subprocess, os, sys

with open(sys.argv[1]) as f:
  diff = f.read()
files = subprocess.run(["git", "diff", "--cached", "--name-only"], capture_output=True, text=True).stdout.strip()
api_key = os.environ.get("ANTHROPIC_API_KEY", "")

prompt = """Write a commit message in this EXACT style. Natural language, no file names.

GOOD examples:
- Add document sync section and mdc file management rule
- Add task completion notification rules and AI analyst strategy toolkit
- remove venv and node_modules from tracking, add to root .gitignore
- fix branch cleanup when no changes are staged
- improve merge flow with auto-merge fallback for CI checks

BAD (never do this):
- update 1 file — docs/cursor-rules-guide.md
- add 3 files, update 2 files — file.ts
- modify config

Format: "Add X and Y" or "remove X, add Y" or "fix X". Max 72 chars. Return ONLY the message, nothing else."""

body = {
  "model": "claude-sonnet-4-20250514",
  "max_tokens": 120,
  "messages": [{"role": "user", "content": prompt + "\n\nFiles:\n" + files + "\n\nDiff:\n" + diff}]
}

r = subprocess.run(
  ["curl", "-s", "--max-time", "20", "-H", "x-api-key: " + api_key,
   "-H", "anthropic-version: 2023-06-01", "-H", "content-type: application/json",
   "https://api.anthropic.com/v1/messages", "-d", json.dumps(body)],
  capture_output=True, text=True
)
try:
  data = json.loads(r.stdout)
  msg = data["content"][0]["text"].strip()
  print(msg[:80] if len(msg) > 80 else msg)
except: pass
PYEOF
)
  rm -f "$tmp"

  [[ -n "$msg" && ${#msg} -le 85 ]] && echo "$msg" && return 0
  return 1
}

smart_fallback() {
  git diff --cached --no-color | python3 -c '
import sys, re, subprocess
diff = sys.stdin.read()
files = subprocess.run(["git", "diff", "--cached", "--name-only"], capture_output=True, text=True).stdout.strip().split("\n") or []

# 목표: "Add X and Y" / "remove X, add Y" 스타일 (파일명 없이, 자연어)
# 예: "Add document sync section and mdc file management rule"
# 예: "remove venv and node_modules from tracking, add to root .gitignore"

titles = []  # 자연어 제목들
path_domains = set()

for f in files:
  if "venv" in f or "node_modules" in f: path_domains.add("venv/node_modules")
  elif "gitignore" in f: path_domains.add("gitignore")
  elif "docs/" in f or "cursor-rules-guide" in f: path_domains.add("docs")
  elif ".mdc" in f or "rules" in f: path_domains.add("cursor rules")
  elif "README" in f: path_domains.add("readme")
  elif "TODO" in f: path_domains.add("todo")
  elif "git-commands" in f: path_domains.add("git commands")

# 1) .gitignore + venv/node_modules 제거 → 고정 패턴
has_venv = any("venv" in f or "node_modules" in f for f in files)
has_gitignore = any("gitignore" in f for f in files)
if has_venv and has_gitignore:
  print("remove venv and node_modules from tracking, add to root .gitignore")
  sys.exit(0)

# 2) 마크다운 ## 헤더 → 자연어 변환
header_map = {
  "규칙 수정 시 문서 동기화": "document sync when cursor rules change",
  "문서 동기화": "document sync section",
  "규칙 파일(mdc) 관리": "mdc file management rule",
  "작업 완료 알림": "task completion notification rules",
  "mdc 규칙 현황": "mdc rules overview",
}
for m in re.findall(r"^\+#{2,6}\s+(.+?)(?:\s*$|\s+#)", diff, re.M):
  h = re.sub(r"\d*️⃣\s*", "", m).strip()
  for kr, en in header_map.items():
    if kr in h:
      titles.append(en)
      break
  else:
    if len(h) > 5 and "(" not in h[:20]:
      titles.append(h[:45].strip())

# 3) - **섹션** 패턴
for m in re.findall(r"^\+[-*]\s+\*\*([^*]+)\*\*", diff, re.M):
  h = m.strip()
  if "규칙" in h or "문서" in h or "동기화" in h: titles.append("document sync and rules")
  elif len(h) > 4: titles.append(h[:35])

# 4) path_domains → 자연어
if "docs" in path_domains and not titles: titles.append("docs")
if "cursor rules" in path_domains: titles.append("cursor rules")
if "gitignore" in path_domains and "remove" not in diff[:200]: titles.append("root .gitignore")
if "git commands" in path_domains: titles.append("git commands")

# 5) 조합: Add X and Y / Add X: Y
seen = set()
parts = []
for t in titles:
  t = t.strip().lower()
  if t and t not in seen and len(t) > 2:
    seen.add(t)
    parts.append(t)
parts = list(dict.fromkeys(parts))[:3]

if parts:
  verb = "Add" if "docs" in str(parts) or "rules" in str(parts) or "규칙" in diff else "Update"
  msg = verb + " " + " and ".join(parts)
  if len(msg) <= 72: print(msg)
' 2>/dev/null
}

generate_commit_msg() {
  # AI 요약 시도 (ANTHROPIC_API_KEY + 크레딧 있을 때)
  local ai_msg
  if ai_msg=$(ai_summarize 2>/dev/null) && [[ -n "$ai_msg" ]]; then
    info "🤖 AI generated"
    echo "$ai_msg"
    return
  fi

  # Smart fallback: diff 내용 분석 (헤더, 경로, 키워드)
  local smart_msg
  smart_msg=$(smart_fallback 2>/dev/null)
  if [[ -n "$smart_msg" && ${#smart_msg} -le 72 ]]; then
    info "⚡ Smart fallback (API 크레딧 부족 시 이 방식 사용)"
    echo "$smart_msg"
    return
  fi

  info "⚡ Basic fallback"

  # 최후 fallback
  local added modified deleted
  added=$(git diff --cached --name-only --diff-filter=A  | wc -l | tr -d ' ')
  modified=$(git diff --cached --name-only --diff-filter=M | wc -l | tr -d ' ')
  deleted=$(git diff --cached --name-only --diff-filter=D  | wc -l | tr -d ' ')

  local parts=()
  (( added > 0 ))    && parts+=("add ${added} file$( (( added > 1 )) && echo s)")
  (( modified > 0 )) && parts+=("update ${modified} file$( (( modified > 1 )) && echo s)")
  (( deleted > 0 ))  && parts+=("remove ${deleted} file$( (( deleted > 1 )) && echo s)")

  [[ ${#parts[@]} -eq 0 ]] && { echo "chore: minor changes"; return; }

  local defs
  defs=$(git diff --cached --no-color | grep '^+[^+]' | grep -oE '(function |def |class |const |let |var |export (default )?(function |class |const ))\w+' | awk '{print $NF}' | sort -u | head -3 | tr '\n' ', ' | sed 's/,$//')
  local top_file
  top_file=$(git diff --cached --numstat | sort -k1 -rn | head -1 | awk '{print $3}')

  if [[ -n "$defs" && -n "$top_file" ]]; then
    echo "$(IFS=', '; echo "${parts[*]}") — ${defs} — ${top_file}"
  elif [[ -n "$defs" ]]; then
    echo "$(IFS=', '; echo "${parts[*]}") — ${defs}"
  elif [[ -n "$top_file" ]]; then
    echo "$(IFS=', '; echo "${parts[*]}") — ${top_file}"
  else
    IFS=', '; echo "${parts[*]}"
  fi
}

COMMIT_MSG=""

if [[ -n "$CUSTOM_MSG" ]]; then
  COMMIT_MSG="$CUSTOM_MSG"
  info "Message: ${YELLOW}${COMMIT_MSG}${NC}"
elif [[ "$AUTO_YES" == true ]]; then
  COMMIT_MSG=$(generate_commit_msg)
  info "Auto: ${YELLOW}${COMMIT_MSG}${NC}"
else
  AUTO_MSG=$(generate_commit_msg)
  echo -e "  Auto: ${YELLOW}${AUTO_MSG}${NC}" >&2
  echo "" >&2
  echo -e "  ${DIM}[Enter]${NC} Use auto message" >&2
  echo -e "  ${DIM}[type]${NC}  Enter custom message" >&2
  echo "" >&2
  read -r -p "  > " USER_INPUT

  if [[ -z "$USER_INPUT" ]]; then
    COMMIT_MSG="$AUTO_MSG"
  else
    COMMIT_MSG="$USER_INPUT"
  fi
fi

dry git commit -m "$COMMIT_MSG"
success "Committed: ${COMMIT_MSG}"
fi

# ─── 4. Pull & Push ────────────────────────────────────────────────
step "4" "Sync Remote"

info "Pulling latest ${DEFAULT_BRANCH}..."
dry git pull origin "$DEFAULT_BRANCH" --rebase --autostash 2>/dev/null || true

info "Pushing ${CURRENT_BRANCH}..."
if ! dry git push -u origin "$CURRENT_BRANCH"; then
  if git ls-remote --exit-code origin "$CURRENT_BRANCH" &>/dev/null; then
    warn "Push rejected (non-fast-forward) — syncing with remote first..."
    dry git pull origin "$CURRENT_BRANCH" --rebase --autostash
    dry git push -u origin "$CURRENT_BRANCH"
  else
    die "Push failed. Check your connection and permissions."
  fi
fi
success "Pushed to origin/${CURRENT_BRANCH}"

# ─── 5. Pull Request ───────────────────────────────────────────────
PR_URL=""
if [[ "$SKIP_PR" == false ]] && [[ "$UNPUSHED_ONLY" != true || "$CURRENT_BRANCH" != "$DEFAULT_BRANCH" ]]; then
  step "5" "Pull Request"

  PR_URL=$(gh pr view "$CURRENT_BRANCH" --json url -q .url 2>/dev/null || true)

  if [[ -n "$PR_URL" ]]; then
    success "PR already exists: ${PR_URL}"
  else
    if [[ "$DRY_RUN" == true ]]; then
      info "${DIM}(dry-run)${NC} gh pr create --title \"${COMMIT_MSG}\" --base ${DEFAULT_BRANCH}"
    else
      PR_URL=$(gh pr create \
        --title "$COMMIT_MSG" \
        --body "Shipped by **git-ship** 🚀" \
        --base "$DEFAULT_BRANCH" \
        --head "$CURRENT_BRANCH" 2>&1) || true
      success "PR created: ${PR_URL}"
    fi
  fi
fi

# ─── 6. Merge ──────────────────────────────────────────────────────
if [[ "$SKIP_MERGE" == false ]] && [[ "$UNPUSHED_ONLY" != true || "$CURRENT_BRANCH" != "$DEFAULT_BRANCH" ]]; then
  step "6" "Merge → ${DEFAULT_BRANCH}"

  if [[ "$DRY_RUN" == true ]]; then
    info "${DIM}(dry-run)${NC} gh pr merge --squash --delete-branch"
  else
    sleep 2

    checkout_default() {
      local did_stash=false
      if ! git diff --quiet 2>/dev/null || ! git diff --staged --quiet 2>/dev/null; then
        info "Stashing local changes before checkout..."
        git stash push -u -m "git-ship: temp stash" && did_stash=true
      fi
      git checkout "$DEFAULT_BRANCH"
      git pull origin "$DEFAULT_BRANCH" --rebase --autostash
      if [[ "$did_stash" == true ]]; then
        git stash pop 2>/dev/null || warn "Stash pop failed — run 'git stash list' to recover"
      fi
    }

    if gh pr merge --squash --delete-branch 2>/dev/null; then
      checkout_default
      success "Merged & branch cleaned up"
    elif gh pr merge --squash --delete-branch --auto 2>/dev/null; then
      success "Auto-merge enabled — will merge when checks pass"
      info "PR: ${PR_URL}"
      checkout_default
    else
      warn "Could not set auto-merge. PR is open at: ${PR_URL}"
      warn "Merge manually when ready."
    fi
  fi
fi

# ─── Done ───────────────────────────────────────────────────────────
echo "" >&2
divider
echo -e "${GREEN}${BOLD}✅ Ship complete!${NC}" >&2
echo "" >&2
